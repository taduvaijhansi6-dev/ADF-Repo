{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "MyfirstDataFlowDemo"
		},
		"ls_destsa_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_destsa'"
		},
		"ls_srcsadf_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_srcsadf'"
		},
		"ls_destsa_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://destsa1712.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "MyfirstDataFlowDemo_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_destsa_accountKey": {
						"value": "[parameters('ls_destsa_accountKey')]"
					},
					"ls_srcsadf_connectionString": {
						"value": "[parameters('ls_srcsadf_connectionString')]"
					},
					"ls_destsa_properties_typeProperties_url": {
						"value": "[parameters('ls_destsa_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}