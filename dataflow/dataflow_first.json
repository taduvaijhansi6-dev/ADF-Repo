{
	"name": "dataflow_first",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "ls_srcsadf",
						"type": "LinkedServiceReference"
					},
					"name": "sourcesrc"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_dest",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filterColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Country as string,",
				"          Year as integer,",
				"          Product_Type as string,",
				"          Sales as short",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     container: 'srccon',",
				"     fileName: 'Sales_File_2020_USA_UK_IND.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourcesrc",
				"sourcesrc filter(Product_Type == 'electronics') ~> filterColumns",
				"sourcesrc sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     rowUrlColumn:'',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}