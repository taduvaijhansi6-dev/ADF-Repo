{
	"name": "df_dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "ls_srcsa_dataflow",
						"type": "LinkedServiceReference"
					},
					"name": "sourcesa"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_destsa",
						"type": "DatasetReference"
					},
					"name": "sinkDAta"
				}
			],
			"transformations": [
				{
					"name": "filterrows"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Country as string,",
				"          Year as integer,",
				"          Product_Type as string,",
				"          Sales as short",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     container: 'srccon',",
				"     fileName: 'Sales_File_2020_USA_UK_IND.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourcesa",
				"sourcesa filter(Country == 'USA') ~> filterrows",
				"filterrows sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkDAta"
			]
		}
	}
}